generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String
  rate      Decimal  @default(1.0) @db.Decimal(20, 10)
  isBase    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shops     Shop[]
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  password        String
  role            Role         @default(USER)
  name            String?
  shopId          String?
  transporterId   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  sales           Sale[]
  shop            Shop?        @relation(fields: [shopId], references: [id])
  transporter     Transporter? @relation(fields: [transporterId], references: [id])
  driverTransports Transfer[]  @relation("AssignedDriver")
}

model Transporter {
  id            String     @id @default(cuid())
  businessId    String?
  name          String
  phone         String?
  vehicleType   String?    // Truck, Van, Bike, etc.
  licensePlate  String?
  address       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  users         User[]
  transports    Transfer[] @relation("Transports")
}

model Warehouse {
  id            String      @id @default(cuid())
  businessId    String?
  name          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  latitude      Float?
  longitude     Float?
  inventory     Inventory[]
  transfersFrom Transfer[]  @relation("TransferFromWarehouse")
  transfersTo   Transfer[]  @relation("TransferToWarehouse")
  invoices      Invoice[]
}

model Shop {
  id            String      @id @default(cuid())
  name          String
  location      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  currencyId    String?
  latitude      Float?
  longitude     Float?
  businessId    String?
  inventory     Inventory[]
  sales         Sale[]
  shifts        Shift[]
  currency      Currency?   @relation(fields: [currencyId], references: [id])
  transfersFrom Transfer[]  @relation("TransferFromShop")
  transfersTo   Transfer[]  @relation("TransferToShop")
  users         User[]
  invoices      Invoice[]
  cashTransfers CashTransfer[]
}

model Product {
  id            String         @id @default(cuid())
  businessId    String?
  name          String
  sku           String         @unique
  description   String?
  price         Decimal?       @db.Decimal(10, 2)
  cost          Decimal?       @default(0) @db.Decimal(10, 2)
  isPriceManual Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  barcode       String?        @unique
  discountPrice Decimal?       @db.Decimal(10, 2)
  inventory     Inventory[]
  invoiceItems  InvoiceItem[]
  saleItems     SaleItem[]
  transferItems TransferItem[]
  imageUrl      String?
  unitId        String?
  unit          ProductUnit?   @relation(fields: [unitId], references: [id])
  categoryId    String?
  category      ProductCategory? @relation(fields: [categoryId], references: [id])

  @@index([businessId])
}

model ProductCategory {
  id          String    @id @default(cuid())
  businessId  String?
  name        String
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId])
}

model ProductUnit {
  id          String    @id @default(cuid())
  businessId  String?
  name        String
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId])
}

model Inventory {
  id          String     @id @default(cuid())
  productId   String
  warehouseId String?
  shopId      String?
  quantity    Int        @default(0)
  product     Product    @relation(fields: [productId], references: [id])
  shop        Shop?      @relation(fields: [shopId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@unique([productId, shopId])
}

model Supplier {
  id            String    @id @default(cuid())
  businessId    String?
  name          String
  email         String?
  phone         String?
  address       String?
  taxId         String?
  contactPerson String?
  website       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  latitude      Float?
  longitude     Float?
  invoices      Invoice[]

  @@index([businessId])
}

model Invoice {
  id         String        @id @default(cuid())
  businessId String?
  warehouseId String?
  shopId     String?
  number     String        @unique
  date       DateTime      @default(now())
  supplierId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  supplier   Supplier?     @relation(fields: [supplierId], references: [id])
  warehouse  Warehouse?    @relation(fields: [warehouseId], references: [id])
  shop       Shop?         @relation(fields: [shopId], references: [id])
  items      InvoiceItem[]

  @@index([businessId])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  productId String
  quantity  Int
  cost      Decimal @db.Decimal(10, 2)
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Transfer {
  id              String         @id @default(cuid())
  businessId      String?
  date            DateTime       @default(now())
  toShopId        String?
  status          String         @default("COMPLETED")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  fromShopId      String?
  fromWarehouseId String?
  toWarehouseId   String?
  fromShop        Shop?          @relation("TransferFromShop", fields: [fromShopId], references: [id])
  fromWarehouse   Warehouse?     @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toShop          Shop?          @relation("TransferToShop", fields: [toShopId], references: [id])
  toWarehouse     Warehouse?     @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  items           TransferItem[]
  transporterId   String?
  driverId        String?
  assignedAt      DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  totalAmount     Decimal?       @db.Decimal(10, 2)
  paidAmount      Decimal?       @db.Decimal(10, 2)
  isPaid          Boolean        @default(false)
  paidAt          DateTime?
  isReturn        Boolean        @default(false)
  parentTransferId String?
  transporter     Transporter?   @relation("Transports", fields: [transporterId], references: [id])
  driver          User?          @relation("AssignedDriver", fields: [driverId], references: [id])

  @@index([businessId])
  @@index([transporterId])
  @@index([driverId])
}

model TransferItem {
  id               String   @id @default(cuid())
  transferId       String
  productId        String
  quantity         Int
  returnedQuantity Int      @default(0)
  returnReason     String?
  product          Product  @relation(fields: [productId], references: [id])
  transfer         Transfer @relation(fields: [transferId], references: [id])
}

model ActivityLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model Customer {
  id         String   @id @default(cuid())
  businessId String?
  name       String
  phone      String?
  email      String?
  address    String?
  taxId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sales      Sale[]

  @@index([businessId])
}

model Shift {
  id          String    @id @default(cuid())
  shopId      String
  userId      String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  openingCash Decimal   @default(0)
  closingCash Decimal?
  actualCash  Decimal?
  difference  Decimal?
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  shop        Shop      @relation(fields: [shopId], references: [id])
  cashTransfers CashTransfer[]

  @@index([shopId])
}

model Sale {
  id             String     @id @default(cuid())
  date           DateTime   @default(now())
  shopId         String
  userId         String
  total          Decimal    @db.Decimal(10, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  currencyCode   String?
  currencyRate   Decimal?   @db.Decimal(20, 10)
  currencySymbol String?
  number         String     @unique
  businessId     String
  customerId     String?
  customer       Customer?  @relation(fields: [customerId], references: [id])
  shop           Shop       @relation(fields: [shopId], references: [id])
  user           User       @relation(fields: [userId], references: [id])
  items          SaleItem[]
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])
}

enum Role {
  ADMIN
  USER
  TRANSPORTER
}

model CashTransfer {
  id        String   @id @default(cuid())
  shopId    String
  shiftId   String?
  amount    Decimal  @db.Decimal(10, 2)
  type      String   @default("TO_ADMIN") // TO_ADMIN, FROM_ADMIN
  status    String   @default("PENDING") // PENDING, COMPLETED, REJECTED
  reference String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id])
  shift     Shift?   @relation(fields: [shiftId], references: [id])

  @@index([shopId])
  @@index([shiftId])
}
